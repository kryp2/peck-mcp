{
  "name": "hackathon-agentic-pay",
  "version": "0.1.0",
  "type": "module",
  "description": "Open Run Agentic Pay hackathon — two AI agents trading via BSV micropayments",
  "scripts": {
    "build": "tsc",
    "agent:a": "node --loader ts-node/esm src/agent-a.ts",
