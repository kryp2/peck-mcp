    "test": "node --loader ts-node/esm src/test-tx.ts"
  },
  "dependencies": {
    "@bsv/sdk": "^2.0.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
