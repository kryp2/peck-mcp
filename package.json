{
  "name": "peck-mcp",
  "version": "0.4.0",
  "type": "module",
  "description": "MCP server giving any LLM a BRC-100 identity, an OS-keychain-resident BSV wallet, and tools for reading + writing the shared Bitcoin Schema social graph (peck.to + 50 other apps). Runs as stdio for local installs or StreamableHTTP for hosted deployments.",
  "bin": {
    "peck-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "bsv",
    "bitcoin-sv",
    "brc-100",
    "bitcoin-schema",
    "agent",
    "peck",
    "social-graph"
  ],
  "author": "kryp2",
  "license": "Open BSV License v5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryp2/peck-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/kryp2/peck-mcp/issues"
  },
  "homepage": "https://github.com/kryp2/peck-mcp#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bsv/sdk": "^2.0.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bitcoin-agent-wallet": "^0.3.3",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
